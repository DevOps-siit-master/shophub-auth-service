# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL) — used from PR2 onwards
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=shophub
DATABASE_PASSWORD=shophub
DATABASE_NAME=shophub_auth

# JWT — used from PR3 onwards
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=7d

# Web3 SIWE — used from PR5 onwards
SIWE_DOMAIN=localhost:3000
SIWE_URI=http://localhost:3000
